# .env.prod.example — Modèle pour la production
# Copier en .env.prod et remplir les valeurs réelles.
# NE JAMAIS commiter .env.prod

# ── Django ────────────────────────────────────────────────────────────────────
# Générer une clé avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=remplacer-par-une-vraie-cle-de-50-caracteres-minimum

DJANGO_SETTINGS_MODULE=CEZIZen.settings_prod
DJANGO_ALLOWED_HOSTS=cesizen.fr,www.cesizen.fr
DJANGO_LOG_LEVEL=WARNING

# ── Email ─────────────────────────────────────────────────────────────────────
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=postmaster@cesizen.fr
EMAIL_HOST_PASSWORD=mot-de-passe-smtp-a-remplacer
DJANGO_DEFAULT_FROM_EMAIL=noreply@cesizen.fr

# ── Base de données MariaDB (production) ──────────────────────────────────────
# Lu par Django (settings_prod.py)
DB_ENGINE=django.db.backends.mysql
DB_NAME=cesizen_prod
DB_USER=cesizen_user
DB_PASSWORD=mot-de-passe-bdd-a-remplacer
DB_HOST=db
DB_PORT=3306

# Lu par le conteneur mariadb lui-même (doit correspondre aux valeurs DB_* ci-dessus)
MYSQL_DATABASE=cesizen_prod
MYSQL_USER=cesizen_user
MYSQL_PASSWORD=mot-de-passe-bdd-a-remplacer
MYSQL_ROOT_PASSWORD=mot-de-passe-root-a-remplacer
