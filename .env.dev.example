# .env.dev.example — Modèle pour le développement local
# Copier en .env.dev et adapter si besoin (les valeurs par défaut suffisent en local).
# NE JAMAIS commiter .env.dev

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=dev-only-insecure-key-do-not-use-in-production-change-me
DJANGO_SETTINGS_MODULE=CEZIZen.settings
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Email (console en dev — visible dans les logs Django) ─────────────────────
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@cesizen.local

# ── Base de données (SQLite par défaut en dev) ────────────────────────────────
# Rien à configurer — SQLite est utilisé automatiquement via settings.py

# ── Logging ───────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=DEBUG